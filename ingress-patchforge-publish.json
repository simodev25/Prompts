  },
  "mission": {
    "objectives": [
      "Identifier et comparer des candidats de correctifs upstream mineurs",
      "Prioriser les correctifs upstream de sécurité, puis fonctionnels, puis de maintenance",
      "Sélectionner un candidat justifié, minimal et applicable",
      "Analyser la pertinence sécurité et supply chain avec l’agent cybersecurity",
      "Analyser les impacts code, build, images, chart et manifestes",
      "Implémenter le patch dès qu’un candidat acceptable existe",
      "Construire systématiquement les artefacts controller et helm-chart",
      "Taguer systématiquement les artefacts produits avec suffixe atos",
      "Pousser systématiquement les images produites vers Docker Hub",
      "Valider le résultat techniquement et fonctionnellement",
      "Produire un rapport final exploitable en français"
    ],
    "non_goals": [
      "Refonte d’architecture",
      "Migration majeure",
      "Changement large hors périmètre",
      "Patch spéculatif sans base upstream",
      "Divergence durable par rapport à la branche cible",
      "Création de PR",
      "Push Git distant"
    ]
  },
  "selection": {
    "preferred_order": [
      "minor-upstream-security-fix",
      "minor-upstream-functional-fix",
      "minor-upstream-maintenance-fix"
    ],
    "constraints": [
      "Conserver un risque au plus moyen",
      "Conserver un périmètre minimal",
      "Privilégier strictement l’upstream",
      "Éviter toute divergence large",
      "Éviter tout changement spéculatif",
      "Ne pas sélectionner de correctif majeur ou transversal"
    ],
    "candidate_rules": {
      "min_candidates_to_review": 2,
      "must_rank_candidates": true,
      "must_explain_selection": true,
      "must_compare_code_impact": true,
      "must_compare_security_impact": true,
      "must_compare_backport_feasibility": true
    }
  },
  "implementation_policy": {
    "patch_is_mandatory_if": [
      "at_least_one_relevant_upstream_minor_candidate_found",
      "candidate_risk_at_most_medium",
      "candidate_scope_is_minimal",
      "candidate_is_backportable_or_directly_applicable"
    ],
    "patch_rules": [
      "patch_must_be_minimal",
      "patch_must_follow_upstream_logic",
      "patch_must_not_introduce_unrelated_changes",
      "patch_must_not_expand_scope_without_explicit_justification",
      "patch_must_prefer_code_fix_over_metadata_only_change"
    ],
    "fallback_if_multiple_candidates": [
      "choose_lowest_risk_candidate",
      "choose_smallest_diff_candidate",
      "choose_candidate_with_strongest_upstream_justification"
    ],
    "build_and_publish_are_mandatory": true,
    "build_even_if_no_patch": true,
    "publish_even_if_no_patch": true,
    "required_artifacts": [
      "controller-image",
      "helm-chart-package"
    ]
  },
  "refusal_policy": {
    "explicit_refusal_allowed": true,
    "refusal_is_exceptional": true,
    "allowed_only_if": [
      "no_relevant_upstream_minor_fix_found_after_review",
      "or_all_reviewed_candidates_exceed_medium_risk",
      "or_all_reviewed_candidates_break_minimal_scope",
      "or_all_reviewed_candidates_are_not_backportable_cleanly"
    ],
    "requirements_if_refused": [
      "state_clear_reason_for_refusal",
      "list_all_reviewed_candidates",
      "explain_why_each_candidate_was_rejected",
      "confirm_that_patch_mandatory_conditions_were_not_met",
      "state_why_non_patch_outcome_is_safer_than_patching",
      "still_build_and_tag_required_artifacts",
      "still_publish_images_if_build_succeeds"
    ],
    "forbidden_refusal_reasons": [
      "insufficient_effort",
      "single_candidate_review_only",
      "metadata_only_comparison_without_code_review",
      "generic_uncertainty_without_evidence"
    ]
  },
